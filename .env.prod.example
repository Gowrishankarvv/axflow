# Production environment variables for axflow on the Hostinger VPS.
# Copy to `.env` on the server and fill in real values.
#
#   cp .env.prod.example .env
#   nano .env

# ---- Django ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# Comma-separated list of hosts Django will accept
ALLOWED_HOSTS=axflow.axinortech.com,localhost,127.0.0.1

# Email domains allowed to register / sign in
ALLOWED_EMAIL_DOMAINS=Axinortech.com

# Origins allowed to call the API (frontend served from same origin → only the public URL needed)
CORS_ALLOWED_ORIGINS=https://axflow.axinortech.com
CSRF_TRUSTED_ORIGINS=https://axflow.axinortech.com

LOG_LEVEL=INFO

# ---- Database (in-container Postgres) ----
POSTGRES_DB=axflow
POSTGRES_USER=axflow
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=replace-with-strong-password

# ---- Slack (optional, leave blank if unused) ----
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_VERIFY_SIGNATURE=1
