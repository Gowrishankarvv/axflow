DJANGO_SECRET_KEY=replace-with-strong-secret
DEBUG=1
DJANGO_ENV=local
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_EMAIL_DOMAINS=Axinortech.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=5

# Security / CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECURE_HSTS_SECONDS=31536000

# Optional cache
# REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Slack bot module
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_VERIFY_SIGNATURE=1
# Slash command should point to: /api/slack/slash-commands/shark/
# Interactivity should point to: /api/slack/task-tracker/interactions/
